            "dec",
            1
          ],
          [
            "inc",
            5
          ]
        ],
        0
      ],
      "expected": [
        -1,
        4
      ]
    },
    {
      "args": [
        [
          [
            "inc",
            1
          ]
        ],
        10
      ],
      "expected": [
        11
      ]
    }
  ],
